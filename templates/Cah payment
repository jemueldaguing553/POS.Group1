<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Payment System</title>

<style>
* {
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    margin: 0;
    background: linear-gradient(135deg, #1e3c72, #2a5298);
    height: 100vh;
    display: flex;
}

.sidebar {
    width: 220px;
    background: #e9eef5;
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.menu-btn {
    padding: 10px;
    border-radius: 10px;
    background: white;
    cursor: pointer;
}

.menu-btn.active {
    background: #2f80ed;
    color: white;
}

.logout {
    margin-top: auto;
}

.main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
}

.card {
    width: 420px;
    background: white;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

.title {
    text-align: center;
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 15px;
}

.amount {
    font-size: 18px;
    margin-bottom: 15px;
}

.amount span {
    font-weight: bold;
}

input {
    width: 100%;
    padding: 12px;
    font-size: 18px;
    border: 2px solid #d0d7e2;
    border-radius: 10px;
    margin-bottom: 10px;
    text-align: right;
}

.change {
    font-size: 16px;
    margin-bottom: 15px;
}

.keypad {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 15px;
}

.keypad button {
    padding: 15px;
    border: none;
    border-radius: 10px;
    background: #f1f4f9;
    cursor: pointer;
}

.actions {
    display: flex;
    gap: 10px;
}

.cancel {
    flex: 1;
    padding: 12px;
    border: none;
    border-radius: 10px;
    background: #ccc;
    cursor: pointer;
}

.confirm {
    flex: 1;
    padding: 12px;
    border: none;
    border-radius: 10px;
    background: #2f80ed;
    color: white;
    cursor: pointer;
}
</style>
</head>

<body>

<div class="sidebar">
    <div class="menu-btn" onclick="goSales()">🛒 Sales</div>
    <div class="menu-btn active">💳 Payment</div>
    <div class="menu-btn">🧾 Receipt</div>
    <div class="menu-btn">📊 Report</div>
    <div class="menu-btn logout">Logout</div>
</div>

<div class="main">

<div class="card">

<div class="title">PAYMENT</div>

<div class="amount">
Total Amount: <span id="amount">₱105</span>
</div>

<input type="text" id="paymentInput" placeholder="Cash Amount Received" readonly>

<div class="change">
Change: ₱<span id="change">0</span>
</div>

<div class="keypad">
    <button onclick="press('1')">1</button>
    <button onclick="press('2')">2</button>
    <button onclick="press('3')">3</button>

    <button onclick="press('4')">4</button>
    <button onclick="press('5')">5</button>
    <button onclick="press('6')">6</button>

    <button onclick="press('7')">7</button>
    <button onclick="press('8')">8</button>
    <button onclick="press('9')">9</button>

    <button onclick="press('00')">00</button>
    <button onclick="press('0')">0</button>
    <button onclick="backspace()">⌫</button>
</div>

<div class="actions">
    <button class="cancel" onclick="cancel()">Cancel</button>
    <button class="confirm" onclick="confirmPayment()">Confirm</button>
</div>

</div>

</div>

<script>

let Amount = 105; // total due
let input = document.getElementById("paymentInput");

function press(val) {
    input.value += val;
    calculate();
}

function backspace() {
    input.value = input.value.slice(0, -1);
    calculate();
}

function calculate() {
    let payment = parseFloat(input.value) || 0;

    let change = payment - Amount;

    document.getElementById("change").innerText =
        change > 0 ? change : 0;
}

function cancel() {
    input.value = "";
    document.getElementById("change").innerText = "0";
}

function confirmPayment() {
    let payment = parseFloat(input.value);

    if (!payment || payment < Amount) {
        alert("Insufficient payment!");
        return;
    }

    alert("Payment Successful!");
    window.location.href = "index.html"; // back to SALES PAGE
}

function goSales() {
    window.location.href = "index.html"; // your sales page file
}

</script>

</body>
</html>
